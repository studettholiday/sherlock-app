ANTHROPIC_API_KEY=your_anthropic_api_key_here
DATABASE_URL=your_database_url_here
PORT=3001

# Web Push (VAPID) — required for schedule-change push notifications.
# Generate the key pair ONCE locally with:
#   npx web-push generate-vapid-keys
# Then paste the values into the Railway dashboard env vars (do NOT commit real keys).
# If these are missing the server still runs — push is simply disabled.
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:guram.obolashvili@gmail.com
